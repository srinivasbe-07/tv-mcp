{
  "name": "tv-mcp",
  "version": "0.1.0",
  "description": "Minimal TradingView MCP server. Connects to TradingView Desktop via Chrome DevTools Protocol.",
  "type": "module",
  "main": "src/server.js",
  "bin": {
    "tv-mcp": "src/server.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "ui": "node ui/server.js",
    "test": "node tests/test-unit.js && node tests/test-bias.js && node tests/test-monitor.js && node tests/test-reports.js",
    "test:unit": "node tests/test-unit.js && node tests/test-bias.js && node tests/test-monitor.js && node tests/test-reports.js",
    "test:live": "node tests/test.js",
    "demo": "node scripts/demo-tools.js",
    "monitor": "node monitors/monitor.js",
    "report": "node scripts/generate-daily-report.js",
    "report:bias": "node scripts/generate-bias-report.js",
    "import-history": "node scripts/import-excel-history.js",
    "eod": "powershell -ExecutionPolicy Bypass -File .\\eod-report.ps1",
    "build": "tsc",
    "start:dist": "node dist/server.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chrome-remote-interface": "^0.33.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/chrome-remote-interface": "^0.34.0",
    "@types/node": "^20.11.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.12.0"
  }
}
