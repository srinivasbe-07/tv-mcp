{
  "name": "tv-mcp",
  "version": "0.1.0",
  "description": "Minimal TradingView MCP server. Connects to TradingView Desktop via Chrome DevTools Protocol.",
  "type": "module",
  "main": "src/server.js",
  "bin": {
    "tv-mcp": "src/server.js"
  },
